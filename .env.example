# Telegram bot token from BotFather
BOT_TOKEN=1234567890:replace_with_real_token

# Telegram numeric user ID of the manager/admin who will receive leads
ADMIN_ID=123456789

# Public HTTPS base URL where this app is reachable
# Example: https://client-acme.example.com
HOST_URL=https://replace-with-your-domain

# Secret token for Telegram webhook header validation
# Use a long random string (32+ chars)
WEBHOOK_SECRET=replace_with_long_random_secret

# Database URL used by SQLAlchemy/Alembic
# If you run with docker-compose from this template, service name "db" works.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/postgres

# Optional values used by docker-compose db service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
